+    If [ty] is [l1:ty1 -> ... -> ln:tyn -> rty], it returns
+    [([(l1, ty1); ...; (ln, tyn)], Ret_type rty)].
+
+    If [ty] is a {e cyclic} arrow type, it returns [([...], Ret_cycle)]. *)
+val arrow_spine
+  :  Env.t
+  -> type_expr
+  -> (arg_label * arrow_arg) list * arrow_ret
